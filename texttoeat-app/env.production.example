# Production (Agila) — template for server .env. Copy to .env on the server; never commit .env.
# See docs/HOSTING_AGILA_SETUP.md. Use with prod branch / main deploy target.

APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.avelinalacasandile-eat.top

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

SESSION_DRIVER=database
SESSION_LIFETIME=120

# Database — Agila uses MySQL (not PostgreSQL). Prefix avelinht_ is added by panel.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Broadcasting — Pusher for realtime staff updates; or set BROADCAST_CONNECTION=null for 30s polling only.
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

# Channel mode: prod = real SMS/Messenger; sim = store only, no real sends
CHANNEL_MODE=prod

CHATBOT_SESSION_TIMEOUT_SECONDS=60
CHATBOT_TAKEOVER_TIMEOUT_MINUTES=60

# Facebook Messenger — from Meta for Developers, Messenger product
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=

# SMS — inbound webhook optional secret; outbound via FCM
TEXTBEE_WEBHOOK_SECRET=
FIREBASE_CREDENTIALS=
# FCM_DEVICE_TOKEN=   # optional, testing
# SMS_DEVICE_API_KEY=

# After upload: php artisan key:generate && php artisan config:cache && php artisan route:cache && php artisan storage:link && php artisan migrate
