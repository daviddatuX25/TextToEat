# Production env template — copy to .env.prod and fill for local build + server reference.
# Do NOT commit .env.prod. Use this file as checklist for production and FB/SMS/FCM.
# Server: copy values to .env on the server (never upload .env.prod with secrets).

# --- App ---
APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.avelinalacasandile-eat.top

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Session / cache / queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# --- Database (Agila MySQL) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=avelinht_eatery_db
DB_USERNAME=avelinht_eatery_admin
DB_PASSWORD=

# --- Build-time (Vite) — used when running npm run build; frontend bakes these in ---
VITE_APP_NAME="${APP_NAME}"
VITE_BROADCAST_BROADCASTER=pusher
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Broadcasting (server .env) — Pusher for realtime; fill from your Pusher dashboard ---
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

# --- Channel mode and real SIM ---
# prod = real SMS and Messenger; sim = simulator only (no real sends).
# Use a real SIM in the Android device and set CHANNEL_MODE=prod so outbound SMS goes via FCM to the device.
CHANNEL_MODE=prod

CHATBOT_SESSION_TIMEOUT_SECONDS=60
CHATBOT_TAKEOVER_TIMEOUT_MINUTES=60

# --- Facebook Messenger (for webhook registration in Meta for Developers) ---
# In Meta → your app → Messenger → Webhooks set:
#   Callback URL: https://www.avelinalacasandile-eat.top/api/messenger/webhook
#   Verify token: use the same value as FACEBOOK_VERIFY_TOKEN below (e.g. copy from .env.prod).
# Subscribe to: messages, messaging_postbacks, etc.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- SMS / Textbee ---
# Inbound webhook URL (set in Textbee app/dashboard): https://www.avelinalacasandile-eat.top/api/sms/incoming
TEXTBEE_API_URL=
TEXTBEE_WEBHOOK_SECRET=

# --- FCM / Firebase (outbound SMS to device) ---
# Upload Firebase service account JSON to the server; set FIREBASE_CREDENTIALS to its path.
# The Android app registers its FCM token and receives send commands via FCM; it POSTs mark-sent to Laravel.
FIREBASE_CREDENTIALS=
FCM_DEVICE_TOKEN=
# Optional: if unset, the app generates and stores a key (QR on SMS devices page uses it)
SMS_DEVICE_API_KEY=
SMS_PENDING_TIMEOUT_MINUTES=10
# Optional: interval (minutes) for app heartbeat; returned in register/update for app sync (default 15)
SMS_HEARTBEAT_INTERVAL_MINUTES=15
