# Local dev — copy to .env. Matches compose.yaml (pgsql). Pusher creds for dev (prod uses GitHub Actions secrets).
# Deploy note: if you ever see the site trying to load `http://localhost:5173` in production,
# it means a `public/hot` file exists on the server. Delete it (our deploy zip excludes it by default).

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=database
SESSION_LIFETIME=120

# DB — pgsql for Sail/compose (see compose.yaml). Run: sail up -d && sail artisan migrate
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Broadcasting — Pusher for dev (no Reverb). Prod build uses GitHub Actions secrets.
BROADCAST_CONNECTION=pusher
VITE_BROADCAST_BROADCASTER=pusher

PUSHER_APP_ID=2121526
PUSHER_APP_KEY=aa0a938372b8d6b2b063
PUSHER_APP_SECRET=ff21b8a37288950f5fb3
PUSHER_APP_CLUSTER=ap1
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://localhost:5173

# Channel mode: sim = no real SMS/Messenger sends (store only)
CHANNEL_MODE=sim

CHATBOT_SESSION_TIMEOUT_SECONDS=60
CHATBOT_TAKEOVER_TIMEOUT_MINUTES=60

# Optional — only if testing FB or SMS in dev
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_VERIFY_TOKEN=
# FACEBOOK_PAGE_ACCESS_TOKEN=
# FIREBASE_CREDENTIALS=
# TEXTBEE_WEBHOOK_SECRET=

# After copying: sail up -d, sail artisan key:generate, sail artisan migrate, sail npm run dev (or npm run dev). Rotate Pusher secret if this file was ever committed.
