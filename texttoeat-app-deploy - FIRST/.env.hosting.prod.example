# Production — for local build + server reference. Do NOT commit.
#
# Deploy notes:
# - The deploy zip excludes `public/hot` (Vite dev marker) so production never tries to load `http://localhost:5173`.
# - The deploy zip excludes `public/storage` (symlink). Create it on the server via `php artisan storage:link`
#   (or via `php-run-scripts`).
# - Vite build-time variables are baked in during the local build (see `.env.prod`), not read from the server `.env`.

# --- App ---
APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.avelinalacasandile-eat.top

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Session / cache / queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# --- Database (Agila MySQL) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=avelinht_eatery_db
DB_USERNAME=avelinht_eatery_admin
DB_PASSWORD=AvelinaLacasandileEatery0123

# --- Build-time (Vite) — frontend bakes these in ---
VITE_APP_NAME="${APP_NAME}"
VITE_BROADCAST_BROADCASTER=pusher
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Broadcasting (Pusher) — same as local .env ---
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=2121526
PUSHER_APP_KEY=aa0a938372b8d6b2b063
PUSHER_APP_SECRET=ff21b8a37288950f5fb3
PUSHER_APP_CLUSTER=ap1

# --- Channel mode ---
CHANNEL_MODE=prod

CHATBOT_SESSION_TIMEOUT_SECONDS=60
CHATBOT_TAKEOVER_TIMEOUT_MINUTES=60

# --- Facebook Messenger ---
# Register in Meta → Messenger → Webhooks: Callback URL = https://www.avelinalacasandile-eat.top/api/messenger/webhook
# Use the value below as "Verify token" in Meta's webhook form.
FACEBOOK_APP_ID=1385567073320557
FACEBOOK_APP_SECRET=fbe6f102179cc8c06ba49ded4193673c
FACEBOOK_VERIFY_TOKEN=texttoeat_fb_verify_a7K9mN2xQ4
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- SMS / Textbee ---
TEXTBEE_API_URL=
TEXTBEE_WEBHOOK_SECRET=

# --- FCM / Firebase ---
# For FIREBASE_CREDENTIALS, put the path to your downloaded service account JSON (Node.js format). Example: ./secure/firebase-service-account.json
FIREBASE_CREDENTIALS=./secure/firebase-service-account.json

# FCM_DEVICE_TOKEN is generated by your device/app after registering with FCM.
FCM_DEVICE_TOKEN=

# SMS_DEVICE_API_KEY is for your SMS gateway/device integration (see project instructions).
SMS_DEVICE_API_KEY=toGodBeTheGloryForeverAndEver

# RUN_SCRIPTS_PASSWORD is used by php-run-scripts/run.php to guard maintenance helpers in production.
RUN_SCRIPTS_PASSWORD=!Xcode092503

SMS_PENDING_TIMEOUT_MINUTES=10
